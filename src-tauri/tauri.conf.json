{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "verilogsim-ide",
  "version": "0.1.0",
  "identifier": "com.verisim.ide",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3077",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "NO_STRIP=1 bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Verisim",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
